{
  "name": "edgesenseai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:start": "cd frontend && npm run start",
    "backend:dev": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8900 --reload",
    "backend:test": "cd backend && pytest -q"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
